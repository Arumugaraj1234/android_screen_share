<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- ══════════════════════════════════════════ -->
    <!--  Top gradient band                        -->
    <!-- ══════════════════════════════════════════ -->
    <View
        android:id="@+id/topBand"
        android:layout_width="0dp"
        android:layout_height="260dp"
        android:background="@drawable/bg_top_band"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- ══════════════════════════════════════════ -->
    <!--  Logo mark                                -->
    <!-- ══════════════════════════════════════════ -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_app_logo"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="52dp"/>

    <!-- ══════════════════════════════════════════ -->
    <!--  App name                                 -->
    <!-- ══════════════════════════════════════════ -->
    <TextView
        android:id="@+id/txtAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:letterSpacing="0.08"
        android:fontFamily="@font/syne_bold"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="14dp"/>

    <TextView
        android:id="@+id/txtTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tagline"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:letterSpacing="0.12"
        android:fontFamily="@font/syne_regular"
        app:layout_constraintTop_toBottomOf="@id/txtAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <!-- ══════════════════════════════════════════ -->
    <!--  Main status card                         -->
    <!-- ══════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardElevation="0dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/txtTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingVertical="28dp">

            <!-- Status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Pulse dot -->
                <FrameLayout
                    android:layout_width="14dp"
                    android:layout_height="14dp">

                    <View
                        android:id="@+id/dotPulse"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/bg_dot_pulse"
                        android:alpha="0.0"/>

                    <View
                        android:id="@+id/dotCore"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_dot_core"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/status_idle"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:fontFamily="@font/syne_regular"
                    android:layout_marginStart="10dp"/>

                <!-- Live badge (hidden when idle) -->
                <TextView
                    android:id="@+id/badgeLive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  LIVE  "
                    android:textColor="@color/accent_green"
                    android:textSize="10sp"
                    android:letterSpacing="0.18"
                    android:fontFamily="@font/syne_bold"
                    android:background="@drawable/bg_badge_live"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="20dp"/>

            <!-- Device ID row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_device_id"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.14"
                android:fontFamily="@font/syne_regular"/>

            <TextView
                android:id="@+id/txtEnterpriseId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/syne_bold"
                android:letterSpacing="0.04"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════ -->
    <!--  Buttons                                  -->
    <!-- ══════════════════════════════════════════ -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_start"
        android:textColor="@color/bg_deep"
        android:textSize="15sp"
        android:letterSpacing="0.06"
        android:fontFamily="@font/syne_bold"
        android:background="@drawable/bg_btn_start"
        android:stateListAnimator="@null"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnStop"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_stop"
        android:textColor="@color/accent_red"
        android:textSize="15sp"
        android:letterSpacing="0.06"
        android:fontFamily="@font/syne_bold"
        android:background="@drawable/bg_btn_stop"
        android:stateListAnimator="@null"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══════════════════════════════════════════ -->
    <!--  Footer                                   -->
    <!-- ══════════════════════════════════════════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/footer_note"
        android:textColor="@color/text_hint"
        android:textSize="11sp"
        android:letterSpacing="0.06"
        android:fontFamily="@font/syne_regular"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>